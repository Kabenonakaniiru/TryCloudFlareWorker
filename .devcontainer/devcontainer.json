{
  "name": "Cloudflare Worker Dev",
  "dockerFile": "Dockerfile",
  "workspaceFolder": "/app/try-cloudflare-worker",
  "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind",
  "customizations": {
    "vscode": {
      "extensions": [
        "cloudflare.workers-extension"
      ]
    }
  },
  "postCreateCommand": "sudo chown -R node:node ${containerWorkspaceFolder} && npm install",
  "forwardPorts": [
    8787
  ],
  "remoteUser": "node",
  "mounts": [
    "source=try-cloudflare-worker-node_modules,target=/app/try-cloudflare-worker/node_modules,type=volume"
  ]
}